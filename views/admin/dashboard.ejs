<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

  <style>
    :root {
      --bg-deep: #07090f;
      --bg-surface: #0d1117;
      --bg-card: #111722;
      --border: rgba(255, 255, 255, 0.07);
      --border-hi: rgba(255, 255, 255, 0.14);
      --accent: #3b82f6;
      --accent-2: #06b6d4;
      --text-hi: #f0f4ff;
      --text-mid: #8b9bba;
      --text-lo: #3d4f6b;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg-deep);
      color: var(--text-hi);
    }

    /* GRID BACKGROUND */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
    }

    /* SIDEBAR */
    .sidebar {
      width: 250px;
      height: 100vh;
      position: fixed;
      background: rgba(13, 17, 23, 0.9);
      backdrop-filter: blur(20px);
      border-right: 1px solid var(--border);
      padding: 22px;
    }

    .sidebar h4 {
      font-weight: 700;
      margin-bottom: 28px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .sidebar a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      color: var(--text-mid);
      text-decoration: none;
      border-radius: 10px;
      margin-bottom: 8px;
      transition: 0.25s;
    }

    .sidebar a:hover {
      background: rgba(59, 130, 246, 0.12);
      color: var(--text-hi);
    }

    .sidebar a.active {
      background: rgba(59, 130, 246, 0.18);
      color: #93c5fd;
    }

    /* MAIN */
    .main {
      margin-left: 250px;
      padding: 26px 34px;
    }

    /* TOPBAR */
    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }

    .topbar h3 {
      font-weight: 700;
    }

    /* PROFILE */
    .profile-box {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      padding: 8px 14px;
      border-radius: 12px;
    }

    .profile-box img {
      width: 36px;
      height: 36px;
      border-radius: 50%;
    }

    .btn-profile {
      background: linear-gradient(135deg, var(--accent), #2563eb);
      border: none;
      color: #fff;
      padding: 7px 14px;
      border-radius: 8px;
      font-size: 0.8rem;
    }

    /* CARDS */
    .stat-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 20px;
      transition: 0.25s;
    }

    .stat-card:hover {
      transform: translateY(-5px);
      border-color: var(--border-hi);
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.5);
    }

    .stat-title {
      font-size: 0.8rem;
      color: var(--text-mid);
      margin-bottom: 6px;
    }

    .stat-value {
      font-size: 1.8rem;
      font-weight: 700;
    }

    /* WELCOME */
    .welcome-card {
      background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(6, 182, 212, 0.08));
      border: 1px solid rgba(59, 130, 246, 0.25);
      border-radius: 18px;
      padding: 22px;
    }

    /* ALERT SYSTEM (UNCHANGED) */
    .alert-container {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .custom-alert {
      min-width: 260px;
      max-width: 320px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 14px;
      border-radius: 14px;
      font-size: 0.85rem;
      backdrop-filter: blur(10px);
      position: relative;
      overflow: hidden;
      animation: slideIn 0.3s ease;
    }

    .alert-left {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .custom-alert.error {
      background: rgba(239, 68, 68, 0.12);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #f87171;
    }

    .custom-alert.success {
      background: rgba(34, 197, 94, 0.12);
      border: 1px solid rgba(34, 197, 94, 0.3);
      color: #4ade80;
    }

    .alert-close {
      background: none;
      border: none;
      color: inherit;
      cursor: pointer;
      opacity: 0.7;
    }

    .alert-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      width: 100%;
      background: currentColor;
      opacity: 0.4;
      animation: shrink 4s linear forwards;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(40px);
      }

      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes shrink {
      from {
        width: 100%;
      }

      to {
        width: 0%;
      }
    }
  </style>
</head>

<body>

  <!-- ALERT -->
  <div class="alert-container">
    <% if (typeof error !=="undefined" && error.length> 0) { %>
      <div class="custom-alert error">
        <div class="alert-left">
          <i class="bi bi-exclamation-circle-fill"></i>
          <span>
            <%= error[0] %>
          </span>
        </div>
        <button class="alert-close" onclick="dismissAlert(this)">
          <i class="bi bi-x-lg"></i>
        </button>
        <div class="alert-bar"></div>
      </div>
      <% } %>

        <% if (typeof success !=="undefined" && success.length> 0) { %>
          <div class="custom-alert success">
            <div class="alert-left">
              <i class="bi bi-check-circle-fill"></i>
              <span>
                <%= success[0] %>
              </span>
            </div>
            <button class="alert-close" onclick="dismissAlert(this)">
              <i class="bi bi-x-lg"></i>
            </button>
            <div class="alert-bar"></div>
          </div>
          <% } %>
  </div>

  <!-- SIDEBAR -->
  <div class="sidebar">
    <h4>⚡ Admin</h4>

    <a href="/admin/dashboard" class="active"><i class="bi bi-speedometer2"></i> Dashboard</a>
    <a href="/admin/profile"><i class="bi bi-person"></i> Profile</a>
    <a href="/admin/dashboard/blogs"><i class="bi bi-journal"></i> Blogs</a>
    <a href="/admin/writers"><i class="bi bi-people"></i> Writers</a>
    <a href="/admin/logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
  </div>

  <!-- MAIN -->
  <div class="main">

    <div class="topbar">
      <h3>Dashboard</h3>

      <div class="profile-box">
        <img src="https://i.pravatar.cc/100">
        <div>
          <div style="font-size:0.85rem">
            <%= admin.adminName %>
          </div>
          <small style="color:var(--text-mid)">Admin</small>
        </div>
        <a href="/admin/profile" class="btn btn-profile">Profile</a>
      </div>
    </div>

    <!-- STATS -->
    <div class="row g-4 mb-4">
      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-title">Total Blogs</div>
          <div class="stat-value">
            <%= blogs.length %>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-title">Total Writers</div>
          <div class="stat-value">
            <%= writers.length %>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-title">Total Users</div>
          <div class="stat-value">
            <%= users.length %>
          </div>
        </div>
      </div>
    </div>

    <!-- WELCOME -->
    <div class="welcome-card">
      <h5>Welcome back, <%= admin.adminName %> 👋</h5>
      <p style="color:var(--text-mid); font-size:0.85rem;">
        Everything is under control. Manage blogs, writers and users from here.
      </p>
    </div>

  </div>

  <script>
    function dismissAlert(btn) {
      const el = btn.closest(".custom-alert");
      el.style.opacity = "0";
      el.style.transform = "translateX(40px)";
      setTimeout(() => el.remove(), 250);
    }

    setTimeout(() => {
      document.querySelectorAll(".custom-alert").forEach(el => {
        el.style.opacity = "0";
        el.style.transform = "translateX(40px)";
        setTimeout(() => el.remove(), 250);
      });
    }, 4000);
  </script>

</body>

</html>