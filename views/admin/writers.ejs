<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> | BlogPlatform
  </title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    :root {
      --primary: #6366f1;
      --secondary: #8b5cf6;
      --bg: #020617;
      --card: rgba(255, 255, 255, 0.05);
      --border: rgba(255, 255, 255, 0.1);
      --text: #f8fafc;
      --muted: #94a3b8;
    }

    body {
      background: radial-gradient(circle at 10% 20%, #1e1b4b, #020617);
      color: var(--text);
      font-family: "Inter", sans-serif;
      margin: 0;
    }

    /* ===== MAIN ===== */
    .main-content {
      padding: 40px 30px;
      max-width: 1100px;
      margin: auto;
    }

    /* ===== HEADER ===== */
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }

    .page-title {
      font-size: 1.8rem;
      font-weight: 800;
    }

    .page-subtitle {
      font-size: 0.85rem;
      color: var(--muted);
      margin-top: 4px;
    }

    .header-actions {
      display: flex;
      gap: 10px;
    }

    .btn-dashboard {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid var(--border);
      color: #fff;
      border-radius: 10px;
    }

    .btn-dashboard:hover {
      background: rgba(255, 255, 255, 0.12);
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      border: none;
      border-radius: 10px;
      font-weight: 600;
    }

    /* ===== CARD ===== */
    .card-glass {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      backdrop-filter: blur(18px);
      padding: 20px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    }

    /* ===== TABLE ===== */
    table {
      width: 100%;
      border-collapse: collapse;
    }

    th {
      font-size: 0.75rem;
      color: var(--muted);
      font-weight: 600;
      padding: 12px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    td {
      padding: 14px 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    tbody tr {
      transition: 0.2s;
    }

    tbody tr:hover {
      background: rgba(255, 255, 255, 0.03);
      transform: scale(1.01);
    }

    /* ===== WRITER CELL ===== */
    .writer-cell {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 600;
    }

    /* ===== BADGES ===== */
    .badge-success {
      background: rgba(34, 197, 94, 0.15);
      color: #4ade80;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 0.75rem;
    }

    .badge-danger {
      background: rgba(239, 68, 68, 0.15);
      color: #f87171;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 0.75rem;
    }

    /* ===== BUTTONS ===== */
    .btn-warning {
      background: rgba(245, 158, 11, 0.2);
      color: #fbbf24;
      border: none;
      border-radius: 8px;
      font-size: 0.75rem;
    }

    .btn-success {
      background: rgba(34, 197, 94, 0.2);
      color: #4ade80;
      border: none;
      border-radius: 8px;
      font-size: 0.75rem;
    }

    .btn:hover {
      transform: translateY(-1px);
      opacity: 0.9;
    }

    /* ===== ALERT ===== */
    .alert-container {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .custom-alert {
      padding: 12px 14px;
      border-radius: 12px;
      backdrop-filter: blur(10px);
      animation: slideIn 0.3s ease;
    }

    .custom-alert.error {
      background: rgba(239, 68, 68, 0.12);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #f87171;
    }

    .custom-alert.success {
      background: rgba(34, 197, 94, 0.12);
      border: 1px solid rgba(34, 197, 94, 0.3);
      color: #4ade80;
    }

    @keyframes slideIn {
      from {
        transform: translateX(40px);
        opacity: 0;
      }

      to {
        transform: translateX(0);
        opacity: 1;
      }
    }

    /* ===== MODAL ===== */
    .modal-content {
      background: #0f172a;
      color: #e2e8f0;
      border: 1px solid var(--border);
      border-radius: 16px;
    }

    .form-control {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border);
      color: #fff;
      border-radius: 10px;
    }

    .form-control:focus {
      background: rgba(255, 255, 255, 0.08);
      border-color: var(--primary);
      box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.3);
      color: #fff;
    }

    .form-label {
      color: var(--muted);
      font-size: 0.8rem;
    }
  </style>
</head>

<body>

  <main class="main-content">

    <!-- ALERTS -->
    <div class="alert-container">
      <% if (error && error.length) { %>
        <div class="custom-alert error">
          <%= error %>
        </div>
        <% } %>

          <% if (success && success.length) { %>
            <div class="custom-alert success">
              <%= success %>
            </div>
            <% } %>
    </div>

    <!-- HEADER -->
    <div class="page-header">
      <div>
        <div class="page-title">Writers</div>
        <div class="page-subtitle">Manage all writer accounts</div>
      </div>

      <div class="header-actions">
        <a href="/admin/dashboard" class="btn btn-dashboard">
          <i class="bi bi-speedometer2"></i>
        </a>

        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createWriterModal">
          <i class="bi bi-plus-lg"></i> Add Writer
        </button>
      </div>
    </div>

    <!-- TABLE -->
    <div class="card-glass">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Writer</th>
            <th>Email</th>
            <th>Status</th>
            <th>Joined</th>
            <th></th>
          </tr>
        </thead>

        <tbody>
          <% writers.forEach((w, i)=> { %>
            <tr>
              <td>
                <%= i + 1 %>
              </td>

              <td>
                <div class="writer-cell">
                  <div class="avatar">
                    <%= w.writerName.charAt(0).toUpperCase() %>
                  </div>
                  <strong>
                    <%= w.writerName %>
                  </strong>
                </div>
              </td>

              <td>
                <%= w.email %>
              </td>

              <td>
                <span class="<%= w.isActive ? 'badge-success' : 'badge-danger' %>">
                  <%= w.isActive ? 'Active' : 'Inactive' %>
                </span>
              </td>

              <td>
                <%= new Date(w.createdAt).toLocaleDateString() %>
              </td>

              <td>
                <form method="POST" action="/admin/writers/<%= w._id %>/toggle">
                  <button class="btn btn-sm <%= w.isActive ? 'btn-warning' : 'btn-success' %>">
                    <%= w.isActive ? 'Deactivate' : 'Activate' %>
                  </button>
                </form>
              </td>
            </tr>
            <% }) %>
        </tbody>
      </table>
    </div>

  </main>

  <!-- MODAL -->
  <div class="modal fade" id="createWriterModal">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">

        <div class="modal-header border-0">
          <h5>Add Writer</h5>
          <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>

        <form action="/admin/create-writer" method="POST">
          <div class="modal-body">

            <label class="form-label">Name</label>
            <input name="writerName" class="form-control mb-3" required>

            <label class="form-label">Email</label>
            <input name="email" type="email" class="form-control mb-3" required>

          </div>

          <div class="modal-footer border-0">
            <button class="btn btn-secondary" data-bs-dismiss="modal" type="button">Cancel</button>
            <button type="submit" class="btn btn-primary">Create</button>
          </div>
        </form>

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    setTimeout(() => {
      document.querySelectorAll(".custom-alert").forEach(el => el.remove());
    }, 4000);
  </script>

</body>

</html>