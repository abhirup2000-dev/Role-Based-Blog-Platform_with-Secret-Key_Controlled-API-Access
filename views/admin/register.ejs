<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title || 'Create Admin' %>
  </title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg-deep: #07090f;
      --bg-card: rgba(255, 255, 255, 0.04);
      --border: rgba(255, 255, 255, 0.08);
      --border-hi: rgba(255, 255, 255, 0.18);
      --accent: #6366f1;
      --accent-2: #8b5cf6;
      --text-hi: #f1f5f9;
      --text-mid: #94a3b8;
      --text-lo: #64748b;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: radial-gradient(circle at 20% 20%, #1e1b4b, #020617);
      color: var(--text-hi);
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      overflow: hidden;
    }

    /* glowing background */
    body::before,
    body::after {
      content: "";
      position: fixed;
      border-radius: 50%;
      filter: blur(100px);
      z-index: 0;
    }

    body::before {
      width: 400px;
      height: 400px;
      background: rgba(99, 102, 241, 0.25);
      top: -100px;
      right: -100px;
    }

    body::after {
      width: 300px;
      height: 300px;
      background: rgba(139, 92, 246, 0.25);
      bottom: -100px;
      left: -100px;
    }

    .auth-wrapper {
      width: 100%;
      max-width: 420px;
      position: relative;
      z-index: 1;
    }

    .auth-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 38px;
      backdrop-filter: blur(25px);
      box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
      animation: fadeUp 0.5s ease;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* header */
    .auth-header {
      text-align: center;
      margin-bottom: 28px;
    }

    .auth-icon {
      width: 64px;
      height: 64px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      margin: 0 auto 14px;
      box-shadow: 0 0 25px rgba(99, 102, 241, 0.4);
    }

    .auth-title {
      font-size: 1.5rem;
      font-weight: 700;
    }

    .auth-sub {
      font-size: 0.8rem;
      color: var(--text-mid);
    }

    /* inputs */
    .form-control {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border-hi);
      border-radius: 12px;
      padding: 12px 14px;
      color: #fff !important;
      -webkit-text-fill-color: #fff !important;
      font-size: 0.88rem;
      transition: all 0.2s;
      caret-color: #fff;
    }

    .form-control:focus {
      background: rgba(255, 255, 255, 0.08);
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
    }

    /* autofill fix */
    input:-webkit-autofill,
    input:-webkit-autofill:focus {
      -webkit-text-fill-color: #fff !important;
      box-shadow: 0 0 0px 1000px rgba(255, 255, 255, 0.05) inset !important;
    }

    /* labels */
    label {
      font-size: 0.7rem;
      margin-bottom: 5px;
      color: var(--text-mid);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* password */
    .pw-wrap {
      position: relative;
    }

    .pw-toggle {
      position: absolute;
      right: 12px;
      top: 68%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: var(--text-lo);
      cursor: pointer;
    }

    .pw-toggle:hover {
      color: var(--text-hi);
    }

    /* button */
    .btn-auth {
      width: 100%;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      border: none;
      padding: 12px;
      border-radius: 12px;
      font-size: 0.9rem;
      font-weight: 600;
      margin-top: 12px;
      transition: all 0.25s;
      box-shadow: 0 6px 20px rgba(99, 102, 241, 0.35);
    }

    .btn-auth:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 30px rgba(99, 102, 241, 0.5);
    }

    /* footer */
    .auth-footer {
      margin-top: 20px;
      text-align: center;
      font-size: 0.8rem;
      color: var(--text-lo);
    }

    .auth-footer a {
      color: #a5b4fc;
      text-decoration: none;
    }

    /* ALERT SYSTEM (UNCHANGED) */
    .alert-container {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .custom-alert {
      min-width: 260px;
      max-width: 320px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 14px;
      border-radius: 14px;
      font-size: 0.85rem;
      backdrop-filter: blur(10px);
      position: relative;
      overflow: hidden;
      animation: slideIn 0.3s ease;
    }

    .alert-left {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .custom-alert.error {
      background: rgba(239, 68, 68, 0.12);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #f87171;
    }

    .custom-alert.success {
      background: rgba(34, 197, 94, 0.12);
      border: 1px solid rgba(34, 197, 94, 0.3);
      color: #4ade80;
    }

    .alert-close {
      background: none;
      border: none;
      color: inherit;
      cursor: pointer;
      opacity: 0.7;
    }

    .alert-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      width: 100%;
      background: currentColor;
      opacity: 0.4;
      animation: shrink 4s linear forwards;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(40px);
      }

      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes shrink {
      from {
        width: 100%;
      }

      to {
        width: 0%;
      }
    }
  </style>
</head>

<body>

  <div class="alert-container">

    <% if (typeof error !=="undefined" && error.length> 0) { %>
      <div class="custom-alert error">
        <div class="alert-left">
          <i class="bi bi-exclamation-circle-fill"></i>
          <span>
            <%= error[0] %>
          </span>
        </div>
        <button class="alert-close" onclick="dismissAlert(this)">
          <i class="bi bi-x-lg"></i>
        </button>
        <div class="alert-bar"></div>
      </div>
      <% } %>

        <% if (typeof success !=="undefined" && success.length> 0) { %>
          <div class="custom-alert success">
            <div class="alert-left">
              <i class="bi bi-check-circle-fill"></i>
              <span>
                <%= success[0] %>
              </span>
            </div>
            <button class="alert-close" onclick="dismissAlert(this)">
              <i class="bi bi-x-lg"></i>
            </button>
            <div class="alert-bar"></div>
          </div>
          <% } %>

  </div>

  <div class="auth-wrapper">
    <div class="auth-card">

      <!-- Header -->
      <div class="auth-header">
        <div class="auth-icon">
          <i class="bi bi-shield-lock"></i>
        </div>
        <div class="auth-title">Create Admin</div>
        <div class="auth-sub">Access control panel</div>
      </div>

      <!-- Form -->
      <form action="/admin/register" method="POST">

        <div class="mb-3">
          <label class="form-label">Name</label>
          <input type="text" name="adminName" class="form-control" required />
        </div>

        <div class="mb-3">
          <label>Email</label>
          <input type="email" name="email" class="form-control" required />
        </div>

        <div class="mb-3">
          <label>Password</label>
          <div class="pw-wrap">
            <input type="password" id="password" name="password" class="form-control" required />
            <button type="button" class="pw-toggle" onclick="togglePw()">
              <i class="bi bi-eye"></i>
            </button>
          </div>
        </div>

        <div class="mb-3">
          <label>Phone</label>
          <input type="text" name="phone" class="form-control" required />
        </div>

        <button type="submit" class="btn-auth">Create Admin</button>

      </form>

      <!-- Footer -->
      <div class="auth-footer">
        Already have account? <a href="/admin/login-view">Login</a>
      </div>

    </div>
  </div>

  <script>
    function togglePw() {
      const input = document.getElementById("password");
      const icon = document.querySelector(".pw-toggle i");

      const isHidden = input.type === "password";
      input.type = isHidden ? "text" : "password";

      icon.classList.toggle("bi-eye");
      icon.classList.toggle("bi-eye-slash");
    }
    function dismissAlert(btn) {
      const el = btn.closest(".custom-alert");
      el.style.opacity = "0";
      el.style.transform = "translateX(40px)";
      setTimeout(() => el.remove(), 250);
    }

    setTimeout(() => {
      document.querySelectorAll(".custom-alert").forEach(el => {
        el.style.opacity = "0";
        el.style.transform = "translateX(40px)";
        setTimeout(() => el.remove(), 250);
      });
    }, 4000);
  </script>

</body>

</html>