<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> | BlogPlatform
  </title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      --primary: #14b8a6;
      --secondary: #0f766e;
      --bg: #020617;
      --card: rgba(255, 255, 255, 0.05);
      --border: rgba(255, 255, 255, 0.1);
      --text: #f8fafc;
      --muted: #94a3b8;
    }

    body {
      font-family: "Inter", sans-serif;
      background: radial-gradient(circle at 20% 20%, #134e4a, #020617);
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text);
      margin: 0;
      overflow: hidden;
    }

    /* glow bg */
    body::before,
    body::after {
      content: "";
      position: fixed;
      border-radius: 50%;
      filter: blur(100px);
      z-index: 0;
    }

    body::before {
      width: 400px;
      height: 400px;
      background: rgba(20, 184, 166, 0.25);
      top: -100px;
      right: -100px;
    }

    body::after {
      width: 300px;
      height: 300px;
      background: rgba(15, 118, 110, 0.25);
      bottom: -100px;
      left: -100px;
    }

    /* card */
    .auth-card {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 420px;
      padding: 40px;
      border-radius: 24px;
      background: var(--card);
      backdrop-filter: blur(25px);
      border: 1px solid var(--border);
      box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
      animation: fadeUp 0.5s ease;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(25px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .auth-header {
      text-align: center;
      margin-bottom: 25px;
    }

    .auth-icon {
      width: 60px;
      height: 60px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      margin: 0 auto 12px;
    }

    .auth-title {
      font-size: 1.6rem;
      font-weight: 700;
    }

    .auth-sub {
      font-size: 0.85rem;
      color: var(--muted);
    }

    /* inputs */
    .form-control {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px;
      color: #fff !important;
    }

    .form-control:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 2px rgba(20, 184, 166, 0.4);
      background: rgba(255, 255, 255, 0.08);
    }

    .form-control::placeholder {
      color: #94a3b8;
    }

    label {
      font-size: 0.75rem;
      color: #cbd5f5;
      margin-bottom: 6px;
    }

    /* password toggle */
    .pw-wrap {
      position: relative;
    }

    .pw-toggle {
      position: absolute;
      right: 12px;
      top: 68%;
      transform: translateY(-50%);
      cursor: pointer;
      color: #94a3b8;
    }

    .pw-toggle:hover {
      color: #fff;
    }

    /* button */
    .btn-auth {
      width: 100%;
      padding: 12px;
      border-radius: 14px;
      border: none;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      font-weight: 600;
      margin-top: 12px;
    }

    .btn-auth:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(20, 184, 166, 0.4);
    }

    .footer {
      margin-top: 18px;
      text-align: center;
      font-size: 0.8rem;
      color: var(--muted);
    }

    .footer a {
      color: #5eead4;
      text-decoration: none;
    }

    /* alerts */
    .alert {
      font-size: 0.8rem;
      border-radius: 10px;
      padding: 10px;
    }

    .alert-danger {
      background: rgba(239, 68, 68, 0.15);
      color: #f87171;
      border: none;
    }

    .alert-success {
      background: rgba(34, 197, 94, 0.15);
      color: #4ade80;
      border: none;
    }
  </style>
</head>

<body>

  <div class="auth-card">

    <div class="auth-header">
      <div class="auth-icon">
        <i class="bi bi-person-plus"></i>
      </div>
      <div class="auth-title">Create Account</div>
      <div class="auth-sub">Join and start engaging with blogs</div>
    </div>

    <% if (error && error.length) { %>
      <div class="alert alert-danger">
        <%= error %>
      </div>
      <% } %>

        <% if (success && success.length) { %>
          <div class="alert alert-success">
            <%= success %>
          </div>
          <% } %>

            <form action="/user/register" method="POST">

              <div class="mb-3">
                <label>Username</label>
                <input type="text" name="userName" class="form-control" placeholder="Enter your name" required>
              </div>

              <div class="mb-3">
                <label>Email</label>
                <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
              </div>

              <div class="mb-3 pw-wrap">
                <label>Password</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Min 6 characters"
                  required minlength="6">
                <i class="bi bi-eye pw-toggle" onclick="togglePw(this)"></i>
              </div>

              <button class="btn-auth">Create Account →</button>

            </form>

            <div class="footer">
              Already have an account? <a href="/user/login-view">Login</a><br>
              <a href="/">← Browse blogs</a>
            </div>

  </div>

  <script>
    function togglePw(el) {
      const input = document.getElementById("password");
      const isHidden = input.type === "password";
      input.type = isHidden ? "text" : "password";

      el.classList.toggle("bi-eye");
      el.classList.toggle("bi-eye-slash");
    }
  </script>

</body>

</html>