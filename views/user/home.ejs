<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

  <style>
    body {
      background: radial-gradient(circle at top, #0b1220, #07090f);
      color: #e2e8f0;
      font-family: 'Inter', sans-serif;
    }

    /* SIDEBAR */
    .sidebar {
      width: 260px;
      height: 100vh;
      position: fixed;
      background: rgba(13, 17, 23, 0.9);
      backdrop-filter: blur(16px);
      border-right: 1px solid rgba(255, 255, 255, 0.06);
      padding: 22px;
    }

    .brand {
      font-weight: 800;
      font-size: 1.2rem;
      margin-bottom: 25px;
      color: #60a5fa;
    }

    .nav-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      color: #94a3b8;
      border-radius: 10px;
      text-decoration: none;
      margin-bottom: 8px;
      transition: 0.2s;
    }

    .nav-link:hover {
      background: rgba(59, 130, 246, 0.12);
      color: #fff;
    }

    /* MAIN */
    .main {
      margin-left: 260px;
      padding: 28px;
    }

    /* TOPBAR */
    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 25px;
    }

    .title {
      font-size: 1.6rem;
      font-weight: 700;
    }

    .profile-box {
      display: flex;
      align-items: center;
      gap: 10px;
      background: rgba(255, 255, 255, 0.05);
      padding: 10px 14px;
      border-radius: 14px;
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .profile-box img {
      width: 42px;
      height: 42px;
      border-radius: 50%;
    }

    .profile-actions {
      display: flex;
      gap: 8px;
      margin-left: 10px;
    }

    .btn-sm-custom {
      font-size: 0.75rem;
      padding: 5px 10px;
      border-radius: 8px;
      border: none;
    }

    .btn-profile {
      background: linear-gradient(135deg, #6366f1, #3b82f6);
      color: #fff;
    }

    .btn-logout {
      background: rgba(239, 68, 68, 0.15);
      color: #f87171;
    }

    /* STATS */
    .card-box {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
      padding: 18px;
      transition: 0.25s;
    }

    .card-box:hover {
      transform: translateY(-5px);
      border-color: rgba(59, 130, 246, 0.4);
    }

    .stat-title {
      color: #94a3b8;
      font-size: 0.8rem;
    }

    .stat-value {
      font-size: 1.6rem;
      font-weight: 700;
    }

    /* FEED */
    .feed-container {
      max-width: 1075px;
      margin: auto;
    }

    .feed-header h4 {
      font-weight: 800;
    }

    .feed-header p {
      color: #94a3b8;
      font-size: 0.9rem;
    }

    .feed-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
      padding: 18px;
      margin-bottom: 18px;
      transition: 0.25s;
    }

    .feed-card:hover {
      transform: translateY(-4px);
      border-color: rgba(99, 102, 241, 0.35);
    }

    .feed-author {
      display: flex;
      gap: 12px;
      align-items: center;
      margin-bottom: 10px;
    }

    .feed-author img {
      width: 42px;
      height: 42px;
      border-radius: 50%;
    }

    .author-name {
      font-weight: 600;
    }

    .meta-line {
      font-size: 12px;
      color: #94a3b8;
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .tag {
      background: rgba(99, 102, 241, 0.15);
      color: #818cf8;
      padding: 3px 8px;
      border-radius: 999px;
      font-size: 11px;
    }

    .feed-title {
      font-size: 1.3rem;
      font-weight: 800;
      margin: 8px 0;
    }

    .feed-title a {
      text-decoration: none;
      color: #e2e8f0;
    }

    .feed-title a:hover {
      color: #93c5fd;
    }

    .feed-excerpt {
      color: #94a3b8;
      font-size: 0.92rem;
    }

    .feed-actions {
      display: flex;
      justify-content: space-between;
      margin-top: 14px;
      font-size: 13px;
      color: #94a3b8;
    }

    .read-btn {
      background: linear-gradient(135deg, #6366f1, #3b82f6);
      color: white;
      padding: 6px 12px;
      border-radius: 10px;
      text-decoration: none;
      font-size: 12px;
    }

    /* ===== ALERT SYSTEM ===== */
    .alert-container {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .custom-alert {
      min-width: 260px;
      max-width: 320px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 14px;
      border-radius: 14px;
      font-size: 0.85rem;
      backdrop-filter: blur(10px);
      position: relative;
      overflow: hidden;
      animation: slideIn 0.3s ease;
    }

    .alert-left {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .custom-alert.error {
      background: rgba(239, 68, 68, 0.12);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #f87171;
    }

    .custom-alert.success {
      background: rgba(34, 197, 94, 0.12);
      border: 1px solid rgba(34, 197, 94, 0.3);
      color: #4ade80;
    }

    .alert-close {
      background: none;
      border: none;
      color: inherit;
      cursor: pointer;
      opacity: 0.7;
    }

    .alert-close:hover {
      opacity: 1;
    }

    .alert-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      width: 100%;
      background: currentColor;
      opacity: 0.4;
      animation: shrink 4s linear forwards;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(40px);
      }

      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes shrink {
      from {
        width: 100%;
      }

      to {
        width: 0%;
      }
    }
  </style>
</head>

<body>

  <div class="alert-container">

    <% if (typeof error !=="undefined" && error.length> 0) { %>
      <div class="custom-alert error">
        <div class="alert-left">
          <i class="bi bi-exclamation-circle-fill"></i>
          <span>
            <%= error[0] %>
          </span>
        </div>
        <button class="alert-close" onclick="dismissAlert(this)">
          <i class="bi bi-x-lg"></i>
        </button>
        <div class="alert-bar"></div>
      </div>
      <% } %>

        <% if (typeof success !=="undefined" && success.length> 0) { %>
          <div class="custom-alert success">
            <div class="alert-left">
              <i class="bi bi-check-circle-fill"></i>
              <span>
                <%= success[0] %>
              </span>
            </div>
            <button class="alert-close" onclick="dismissAlert(this)">
              <i class="bi bi-x-lg"></i>
            </button>
            <div class="alert-bar"></div>
          </div>
          <% } %>

  </div>

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="brand">BlogPlatform</div>

    <a class="nav-link" href="/user/home"><i class="bi bi-house"></i> Home</a>
    <a class="nav-link" href="/user/profile"><i class="bi bi-person-circle"></i> Profile</a>
    <a class="nav-link" href="/user/bookmarks"><i class="bi bi-bookmark"></i> Bookmarks</a>
    <a class="nav-link" href="/user/logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- TOP -->
    <div class="topbar">
      <div class="title">Welcome back 👋</div>

      <div class="profile-box">
        <img src="https://i.pravatar.cc/100">

        <div>
          <div style="font-weight:600">
            <%= user.userName %>
          </div>
        </div>

        <div class="profile-actions">
          <a href="/user/profile" class="btn btn-sm-custom btn-profile">Profile</a>
          <a href="/user/logout" class="btn btn-sm-custom btn-logout">Logout</a>
        </div>
      </div>
    </div>

    <!-- STATS -->
    <div class="row g-3 mb-4">

      <div class="col-md-4">
        <div class="card-box">
          <div class="stat-title">Total Blogs</div>
          <div class="stat-value">
            <%= blogs.length %>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card-box">
          <div class="stat-title">Feed Status</div>
          <div class="stat-value">🔥 Live</div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card-box">
          <div class="stat-title">Account</div>
          <div class="stat-value"><%= user.isActive ? "Active" : "Inactive" %></div>
        </div>
      </div>

    </div>

    <!-- FEED -->
    <div class="feed-container">

      <div class="feed-header mb-3">
        <h4>🔥 Latest Stories</h4>
        <p>Discover what the community is reading right now</p>
      </div>

      <% blogs.forEach(blog=> { %>

        <div class="feed-card">

          <!-- AUTHOR -->
          <div class="feed-author">
            <img src="https://i.pravatar.cc/100?u=<%= blog._id %>">

            <div>
              <div class="author-name">
                <%= blog.author?.writerName || "Unknown Author" %>
              </div>

              <div class="meta-line">
                <span>
                  <%= new Date(blog.createdAt).toDateString() %>
                </span>
                <span>•</span>
                <span class="tag">
                  <%= blog.category || "General" %>
                </span>
              </div>
            </div>
          </div>

          <!-- TITLE -->
          <div class="feed-title">
            <a href="/blog/<%= blog._id %>">
              <%= blog.title %>
            </a>
          </div>

          <!-- EXCERPT -->
          <p class="feed-excerpt">
            <%= blog.content.substring(0, 180) %>...
          </p>

          <!-- ACTIONS -->
          <div class="feed-actions">
            <div>
              ❤️ <%= blog.totalLikes %> Likes
                💬 <%= blog.totalComments %> Comments
            </div>

            <a href="/user/view-blog/<%= blog._id %>" class="read-btn">
              Read →
            </a>
          </div>

        </div>

        <% }) %>

    </div>

  </div>

  <script>
    function dismissAlert(btn) {
      const el = btn.closest(".custom-alert");
      el.style.opacity = "0";
      el.style.transform = "translateX(40px)";
      setTimeout(() => el.remove(), 250);
    }

    setTimeout(() => {
      document.querySelectorAll(".custom-alert").forEach(el => {
        el.style.opacity = "0";
        el.style.transform = "translateX(40px)";
        setTimeout(() => el.remove(), 250);
      });
    }, 4000);
  </script>

</body>

</html>