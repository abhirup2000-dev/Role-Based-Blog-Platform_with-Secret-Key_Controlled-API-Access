<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= blog.title %>
  </title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

  <style>
    body {
      background: #0b1220;
      color: #e5e7eb;
      font-family: 'Inter', sans-serif;
    }

    .wrapper {
      max-width: 900px;
      margin: 40px auto;
      padding: 0 18px;
    }

    /* ARTICLE */
    .article {
      background: #111827;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 18px;
      padding: 28px;
    }

    /* AUTHOR BAR */
    .author-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 22px;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .author-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .author-left img {
      width: 48px;
      height: 48px;
      border-radius: 50%;
    }

    .author-name {
      font-weight: 600;
      font-size: 14px;
    }

    .meta {
      font-size: 12px;
      color: #94a3b8;
    }

    .badge-cat {
      background: rgba(59, 130, 246, 0.15);
      color: #60a5fa;
      padding: 5px 10px;
      border-radius: 999px;
      font-size: 11px;
    }

    /* TITLE */
    .title {
      font-size: 2rem;
      font-weight: 800;
      margin-bottom: 16px;
      line-height: 1.3;
    }

    /* CONTENT */
    .content {
      font-size: 15.5px;
      line-height: 1.9;
      color: #cbd5e1;
      white-space: pre-line;
    }

    /* ACTION BAR */
    .actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 22px;
      padding-top: 16px;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .btn-like {
      background: rgba(239, 68, 68, 0.08);
      border: 1px solid rgba(239, 68, 68, 0.25);
      color: #f87171;
      padding: 8px 14px;
      border-radius: 10px;
      font-size: 13px;
      transition: 0.2s;
    }

    .btn-like:hover {
      background: rgba(239, 68, 68, 0.15);
      transform: translateY(-1px);
    }

    /* COMMENTS */
    .comment-section {
      margin-top: 30px;
    }

    .comment-title {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 14px;
    }

    .comment-form {
      background: #111827;
      border: 1px solid rgba(255, 255, 255, 0.06);
      padding: 14px;
      border-radius: 14px;
      margin-bottom: 18px;
    }

    .comment-form input {
      width: 100%;
      padding: 10px;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: #0f172a;
      color: white;
      outline: none;
    }

    .btn-send {
      margin-top: 10px;
      background: linear-gradient(135deg, #3b82f6, #6366f1);
      border: none;
      padding: 8px 14px;
      border-radius: 10px;
      color: white;
      font-size: 13px;
    }

    /* COMMENT CARD */
    .comment {
      background: #111827;
      border: 1px solid rgba(255, 255, 255, 0.06);
      padding: 12px;
      border-radius: 12px;
      margin-bottom: 10px;
    }

    .comment-user {
      font-size: 13px;
      font-weight: 600;
      color: #93c5fd;
    }

    .comment-text {
      font-size: 14px;
      color: #cbd5e1;
      margin-top: 4px;
    }

    /* MOBILE */
    @media (max-width: 768px) {
      .title {
        font-size: 1.5rem;
      }
    }
  </style>
</head>

<body>

  <div class="wrapper">

    <!-- ARTICLE -->
    <div class="article">

      <!-- AUTHOR -->
      <div class="author-bar">

        <div class="author-left">
          <img src="https://i.pravatar.cc/100?u=<%= blog._id %>">

          <div>
            <div class="author-name">
              <%= blog.author?.writerName || "Unknown Author" %>
            </div>
            <div class="meta">
              <%= new Date(blog.createdAt).toDateString() %>
            </div>
          </div>
        </div>

        <span class="badge-cat">
          <%= blog.category || "General" %>
        </span>

      </div>

      <!-- TITLE -->
      <div class="title">
        <%= blog.title %>
      </div>

      <!-- CONTENT -->
      <div class="content">
        <%= blog.content %>
      </div>

      <!-- ACTIONS -->
      <div class="actions">

        <form action="/user/blog/like/<%= blog._id %>" method="POST">
          <button class="btn-like">
            ❤️ <%= blog.likes?.length || 0 %> Like
          </button>
        </form>

        <span style="color:#94a3b8;font-size:13px">
          💬 <%= blog.comments?.length || 0 %> Comments
        </span>

      </div>

    </div>

    <!-- COMMENTS -->
    <div class="comment-section">

      <div class="comment-title">💬 Discussion</div>

      <!-- FORM -->
      <form class="comment-form" action="/user/blog/comment/<%= blog._id %>" method="POST">
        <input type="text" name="content" placeholder="Write your thoughts..." required>
        <button type="submit" class="btn-send">Post Comment</button>
      </form>

      <!-- LIST -->
      <% if (blog.comments && blog.comments.length) { %>

        <% blog.comments.forEach(c=> { %>

          <div class="comment">

            <div class="comment-user">
              <%= c.user?.userName || "User" %>
            </div>

            <div class="comment-text">
              <%= c.content %>
            </div>

          </div>

          <% }) %>

            <% } else { %>
              <p style="color:#94a3b8">No comments yet. Start the conversation 🚀</p>
              <% } %>

    </div>

  </div>

</body>

</html>