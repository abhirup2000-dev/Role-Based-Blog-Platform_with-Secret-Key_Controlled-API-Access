<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Writer Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />

  <style>
    :root {
      --bg-deep: #07090f;
      --bg-surface: #0d1117;
      --bg-card: #111722;
      --border: rgba(255, 255, 255, 0.07);
      --border-hi: rgba(255, 255, 255, 0.14);
      --accent: #8b5cf6;
      --accent-2: #06b6d4;
      --text-hi: #f0f4ff;
      --text-mid: #8b9bba;
      --text-lo: #3d4f6b;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg-deep);
      color: var(--text-hi);
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
    }

    /* SIDEBAR */
    .sidebar {
      width: 250px;
      height: 100vh;
      position: fixed;
      background: rgba(13, 17, 23, 0.9);
      backdrop-filter: blur(20px);
      border-right: 1px solid var(--border);
      padding: 22px;
    }

    .sidebar h4 {
      font-weight: 700;
      margin-bottom: 28px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .sidebar a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      color: var(--text-mid);
      text-decoration: none;
      border-radius: 10px;
      margin-bottom: 8px;
      transition: 0.25s;
    }

    .sidebar a:hover {
      background: rgba(139, 92, 246, 0.12);
      color: var(--text-hi);
    }

    .sidebar a.active {
      background: rgba(139, 92, 246, 0.18);
      color: #c4b5fd;
    }

    /* MAIN */
    .main {
      margin-left: 250px;
      padding: 26px 34px;
    }

    /* TOPBAR */
    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }

    .profile-box {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      padding: 8px 14px;
      border-radius: 12px;
    }

    .profile-box img {
      width: 36px;
      height: 36px;
      border-radius: 50%;
    }

    .btn-profile {
      background: linear-gradient(135deg, var(--accent), #7c3aed);
      border: none;
      color: #fff;
      padding: 7px 14px;
      border-radius: 8px;
      font-size: 0.8rem;
    }

    /* CARDS */
    .stat-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 20px;
      transition: 0.25s;
    }

    .stat-card:hover {
      transform: translateY(-5px);
      border-color: var(--border-hi);
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.5);
    }

    .stat-title {
      font-size: 0.8rem;
      color: var(--text-mid);
      margin-bottom: 6px;
    }

    .stat-value {
      font-size: 1.8rem;
      font-weight: 700;
    }

    /* WELCOME */
    .welcome-card {
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(6, 182, 212, 0.08));
      border: 1px solid rgba(139, 92, 246, 0.25);
      border-radius: 18px;
      padding: 22px;
    }

    /* ALERT */
    .alert-container {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .custom-alert {
      min-width: 260px;
      padding: 12px;
      border-radius: 12px;
      font-size: 0.85rem;
    }

    .custom-alert.error {
      background: rgba(239, 68, 68, 0.2);
    }

    .custom-alert.success {
      background: rgba(34, 197, 94, 0.2);
    }
  </style>
</head>

<body>

  <!-- ALERT -->
  <div class="alert-container">
    <% if (error?.length) { %>
      <div class="custom-alert error">
        <%= error[0] %>
      </div>
      <% } %>

        <% if (success?.length) { %>
          <div class="custom-alert success">
            <%= success[0] %>
          </div>
          <% } %>
  </div>

  <!-- SIDEBAR -->
  <div class="sidebar">
    <h4>✍️ Writer</h4>

    <a href="/writer/dashboard" class="active"><i class="bi bi-speedometer2"></i> Dashboard</a>
    <a href="/writer/blogs"><i class="bi bi-journal-text"></i> My Blogs</a>
    <a href="/writer/profile"><i class="bi bi-person"></i> Profile</a>
    <a href="/writer/logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
  </div>

  <!-- MAIN -->
  <div class="main">

    <div class="topbar">
      <h3>Dashboard</h3>

      <div class="profile-box">
        <img src="https://i.pravatar.cc/100">
        <div>
          <div style="font-size:0.85rem">
            <%= writer.writerName %>
          </div>
          <small style="color:var(--text-mid)">Writer</small>
        </div>
        <a href="/writer/profile" class="btn btn-profile">Profile</a>
      </div>
    </div>

    <!-- STATS -->
    <div class="row g-4 mb-4">
      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-title">My Blogs</div>
          <div class="stat-value">
            <%= blogs.length %>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-title">Published</div>
          <div class="stat-value">
            <%= publishedCount %>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="stat-card">
          <div class="stat-title">Drafts</div>
          <div class="stat-value">
            <%= draftCount %>
          </div>
        </div>
      </div>
    </div>

    <!-- WELCOME -->
    <div class="welcome-card">
      <h5>Hey <%= writer.writerName %> 👋</h5>
      <p style="color:var(--text-mid); font-size:0.85rem;">
        Ready to drop another banger blog? Let’s go 🚀
      </p>
    </div>

  </div>

  <script>
    function dismissAlert(btn) {
      const el = btn.closest(".custom-alert");
      el.style.opacity = "0";
      setTimeout(() => el.remove(), 250);
    }

    setTimeout(() => {
      document.querySelectorAll(".custom-alert").forEach(el => {
        el.style.opacity = "0";
        setTimeout(() => el.remove(), 250);
      });
    }, 4000);
  </script>

</body>

</html>