<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | BlogPlatform</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
<nav class="navbar">
  <a href="/writer/dashboard" class="navbar-brand">✍️ Writer Panel</a>
  <div class="navbar-nav">
    <a href="/writer/dashboard" class="nav-link active">Dashboard</a>
    <a href="/writer/blogs" class="nav-link">My Blogs</a>
    <a href="/writer/logout" class="btn btn-ghost btn-sm">Logout</a>
  </div>
</nav>

<div class="content-wrapper">
  <div class="container">
    <div class="page-header">
      <div>
        <h1 class="page-title">My Dashboard</h1>
        <p class="page-subtitle">Welcome back, <%= user.name %>!</p>
      </div>
      <a href="/writer/blogs" class="btn btn-primary">+ New Blog</a>
    </div>

    <% if (error && error.length) { %><div class="alert alert-error" data-autodismiss><span>⚠️ <%= error %></span></div><% } %>
    <% if (success && success.length) { %><div class="alert alert-success" data-autodismiss><span>✅ <%= success %></span></div><% } %>

    <!-- Stats -->
    <div class="grid grid-4 mb-3">
      <div class="stat-card">
        <div class="stat-icon blue">📝</div>
        <div><div class="stat-value"><%= stats.totalBlogs %></div><div class="stat-label">Total Blogs</div></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon gray">🗒️</div>
        <div><div class="stat-value"><%= stats.draftBlogs %></div><div class="stat-label">Drafts</div></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon yellow">⏳</div>
        <div><div class="stat-value"><%= stats.pendingBlogs %></div><div class="stat-label">Pending Review</div></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green">✅</div>
        <div><div class="stat-value"><%= stats.publishedBlogs %></div><div class="stat-label">Published</div></div>
      </div>
    </div>

    <!-- Recent Blogs -->
    <div class="card">
      <div class="card-header">
        <h3>Recent Blogs</h3>
        <a href="/writer/blogs" class="btn btn-outline btn-sm">View All</a>
      </div>
      <div class="table-wrapper">
        <table>
          <thead><tr><th>Title</th><th>Category</th><th>Status</th><th>Date</th></tr></thead>
          <tbody>
            <% if (recentBlogs.length === 0) { %>
              <tr><td colspan="4" style="padding:2rem; text-align:center; color:var(--gray-500)">
                No blogs yet. <a href="/writer/blogs">Create your first blog!</a>
              </td></tr>
            <% } else { %>
              <% recentBlogs.forEach(blog => { %>
                <tr>
                  <td><span class="truncate" style="max-width:280px; display:block"><%= blog.title %></span></td>
                  <td class="text-sm"><%= blog.category ? blog.category.name : '—' %></td>
                  <td>
                    <span class="badge <%= blog.status==='published'?'badge-success':blog.status==='pending'?'badge-warning':'badge-gray' %>">
                      <%= blog.status %>
                    </span>
                  </td>
                  <td class="text-sm text-muted"><%= new Date(blog.createdAt).toLocaleDateString() %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <% if (stats.pendingBlogs > 0) { %>
      <div class="alert alert-warning mt-2">
        <span>⏳ You have <strong><%= stats.pendingBlogs %></strong> blog(s) awaiting admin approval.</span>
      </div>
    <% } %>
  </div>
</div>

<div id="ws-toast"></div>
<script src="/js/app.js"></script>
<script>initWebSocketNotifications('<%= user.id %>', 'writer');</script>
</body>
</html>
