<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

  <style>
    :root {
      --bg: #050816;
      --card: rgba(255, 255, 255, 0.06);
      --border: rgba(255, 255, 255, 0.08);
      --accent: #ec4899;
      --accent2: #8b5cf6;
      --text: #e2e8f0;
      --muted: #94a3b8;
    }

    body {
      background: linear-gradient(120deg, #020617, #0f172a);
      color: var(--text);
      font-family: "Inter", sans-serif;
      min-height: 100vh;
    }

    .container {
      max-width: 900px;
      margin-top: 60px;
    }

    .card-box {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 24px;
      margin-bottom: 24px;
      backdrop-filter: blur(18px);
      transition: 0.3s;
    }

    .card-box:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 255, 255, 0.2);
    }

    /* HEADER */
    .profile-header {
      text-align: center;
    }

    .avatar {
      width: 90px;
      height: 90px;
      border-radius: 50%;
      margin: auto;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      box-shadow: 0 10px 30px rgba(236, 72, 153, 0.5);
    }

    .name {
      font-size: 1.3rem;
      font-weight: 700;
      margin-top: 12px;
    }

    .role {
      font-size: 0.8rem;
      color: var(--muted);
    }

    /* INFO GRID */
    .info {
      background: rgba(255, 255, 255, 0.04);
      padding: 14px;
      border-radius: 12px;
      border: 1px solid var(--border);
    }

    .label {
      font-size: 0.7rem;
      color: var(--muted);
    }

    .value {
      font-weight: 600;
      font-size: 0.9rem;
    }

    /* FORM */
    input {
      background: rgba(255, 255, 255, 0.05) !important;
      border: 1px solid var(--border) !important;
      color: #fff !important;
      border-radius: 10px !important;
      padding: 10px;
    }

    input:focus {
      border-color: var(--accent) !important;
      box-shadow: 0 0 0 2px rgba(236, 72, 153, 0.3) !important;
    }

    .btn-main {
      width: 100%;
      padding: 10px;
      border-radius: 12px;
      border: none;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      color: white;
      font-weight: 600;
      transition: 0.25s;
    }

    .btn-main:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(236, 72, 153, 0.5);
    }

    h6 {
      margin-bottom: 15px;
    }

    /* ALERT SYSTEM (UNCHANGED) */
    .alert-container {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .custom-alert {
      min-width: 260px;
      max-width: 320px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 14px;
      border-radius: 14px;
      font-size: 0.85rem;
      backdrop-filter: blur(10px);
      position: relative;
      overflow: hidden;
      animation: slideIn 0.3s ease;
    }

    .alert-left {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .custom-alert.error {
      background: rgba(239, 68, 68, 0.12);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: #f87171;
    }

    .custom-alert.success {
      background: rgba(34, 197, 94, 0.12);
      border: 1px solid rgba(34, 197, 94, 0.3);
      color: #4ade80;
    }

    .alert-close {
      background: none;
      border: none;
      color: inherit;
      cursor: pointer;
      opacity: 0.7;
    }

    .alert-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      width: 100%;
      background: currentColor;
      opacity: 0.4;
      animation: shrink 4s linear forwards;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(40px);
      }

      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes shrink {
      from {
        width: 100%;
      }

      to {
        width: 0%;
      }
    }
  </style>
</head>

<body>

  <!-- ALERT -->
  <div class="alert-container">
    <% if (typeof error !=="undefined" && error.length> 0) { %>
      <div class="custom-alert error">
        <div class="alert-left">
          <i class="bi bi-exclamation-circle-fill"></i>
          <span>
            <%= error[0] %>
          </span>
        </div>
        <button class="alert-close" onclick="dismissAlert(this)">
          <i class="bi bi-x-lg"></i>
        </button>
        <div class="alert-bar"></div>
      </div>
      <% } %>

        <% if (typeof success !=="undefined" && success.length> 0) { %>
          <div class="custom-alert success">
            <div class="alert-left">
              <i class="bi bi-check-circle-fill"></i>
              <span>
                <%= success[0] %>
              </span>
            </div>
            <button class="alert-close" onclick="dismissAlert(this)">
              <i class="bi bi-x-lg"></i>
            </button>
            <div class="alert-bar"></div>
          </div>
          <% } %>
  </div>

  <div class="container">

    <!-- PROFILE HEADER -->
    <div class="card-box profile-header">
      <div class="avatar">
        <i class="bi bi-pen"></i>
      </div>
      <div class="name">
        <%= writer.writerName %>
      </div>
      <div class="role">Content Writer ✍️</div>
    </div>

    <!-- INFO -->
    <div class="card-box">
      <h6>Profile Info</h6>

      <div class="row g-3">
        <div class="col-md-6">
          <div class="info">
            <div class="label">Full Name</div>
            <div class="value">
              <%= writer.writerName %>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="info">
            <div class="label">Email</div>
            <div class="value">
              <%= writer.email %>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="info">
            <div class="label">Writer ID</div>
            <div class="value">
              <%= writer._id %>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="info">
            <div class="label">Joined</div>
            <div class="value">
              <%= new Date(writer.createdAt).toLocaleDateString() %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- PASSWORD -->
    <div class="card-box">
      <h6>Change Password</h6>

      <form action="/writer/password-update" method="POST">
        <div class="mb-3">
          <label>Current Password</label>
          <input type="password" name="currentPassword" required>
        </div>

        <div class="mb-3">
          <label>New Password</label>
          <input type="password" name="newPassword" required>
        </div>

        <button type="submit" class="btn-main">Update Password</button>
      </form>
    </div>

  </div>


  <script>
    function togglePw(el) {
      const input = el.closest(".pw-wrapper").querySelector("input");
      const hidden = input.type === "password";
      input.type = hidden ? "text" : "password";
      el.classList.toggle("bi-eye");
      el.classList.toggle("bi-eye-slash");
    }

    function dismissAlert(btn) {
      const el = btn.closest(".custom-alert");
      el.style.opacity = "0";
      el.style.transform = "translateX(40px)";
      setTimeout(() => el.remove(), 250);
    }

    setTimeout(() => {
      document.querySelectorAll(".custom-alert").forEach(el => {
        el.style.opacity = "0";
        el.style.transform = "translateX(40px)";
        setTimeout(() => el.remove(), 250);
      });
    }, 4000);
  </script>

</body>

</html>